---
import type { HTMLAttributes } from "astro/types";
interface Props extends HTMLAttributes<"video"> {
  src: string;
}

const {
  src,
  controls = true,
  loop = true,
  playsinline = true,
  muted = true,
  autoplay = true,
  ...videoProps
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const prefix = baseUrl.endsWith("/") ? baseUrl : baseUrl + "/";
const resolvedSrc = src.startsWith("/") || src.startsWith("http") ? src : prefix + src;
---

<video
  class="aspect-video h-auto w-full rounded-lg"
  controls={controls}
  loop={loop}
  playsinline={playsinline}
  muted={muted}
  autoplay={autoplay}
  preload="auto"
  {...videoProps}>
  <source src={resolvedSrc} type="video/mp4" />
  Your browser does not support the video tag.
</video>
